---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'AnimeFLV - Ver Anime Online' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ver anime online gratis en HD. Disfruta de tus animes favoritos con subtítulos en español y versión doblada." />
    <meta name="keywords" content="anime, streaming, manga, series, doblado, subtitulado" />
    <meta name="theme-color" content="#e63946" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html {
    background-color: #0d0d0d;
  }
</style>
