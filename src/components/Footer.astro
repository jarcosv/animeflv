<footer class="footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-logo-section">
        <img src="/logo.png" height="48" alt="AnimeFLV Logo" />
        <p>El mejor sitio para ver anime online gratis en HD</p>
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-section">
        <h3 class="footer-title">Géneros</h3>
        <ul class="footer-links">
          <li><a href="/">Acción</a></li>
          <li><a href="/">Aventura</a></li>
          <li><a href="/">Comedia</a></li>
          <li><a href="/">Drama</a></li>
          <li><a href="/">Fantasía</a></li>
          <li><a href="/">Romance</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h3 class="footer-title">Tipo</h3>
        <ul class="footer-links">
          <li><a href="/">Anime</a></li>
          <li><a href="/">Manga</a></li>
          <li><a href="/">Película</a></li>
          <li><a href="/">OVA</a></li>
          <li><a href="/">Especial</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h3 class="footer-title">Información</h3>
        <ul class="footer-links">
          <li><a href="/">Acerca de</a></li>
          <li><a href="/">Contacto</a></li>
          <li><a href="/">Privacidad</a></li>
          <li><a href="/">Términos</a></li>
          <li><a href="/">FAQ</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h3 class="footer-title">Redes Sociales</h3>
        <ul class="footer-links">
          <li><a href="/">Facebook</a></li>
          <li><a href="/">Twitter</a></li>
          <li><a href="/">Instagram</a></li>
          <li><a href="/">Discord</a></li>
          <li><a href="/">YouTube</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© 2025 — Los videos son propiedad de sus respectivos dueños.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 40px;
    margin-top: 48px;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .footer-top {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid #1a1a1a;
  }

  .footer-logo-section {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .footer-logo-section img {
    height: 48px;
    width: auto;
  }

  .footer-logo-section p {
    color: #666666;
    font-size: 14px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 40px;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-title {
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 8px;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-links a {
    color: #666666;
    font-size: 13px;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #e63946;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 32px;
    border-top: 1px solid #1a1a1a;
    color: #555555;
    font-size: 12px;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 32px 24px;
    }

    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      margin-bottom: 24px;
    }

    .footer-top {
      margin-bottom: 24px;
      padding-bottom: 24px;
    }
  }

  @media (max-width: 480px) {
    .footer {
      padding: 24px 16px;
    }

    .footer-logo-section {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .footer-logo-section p {
      font-size: 12px;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .footer-title {
      font-size: 13px;
    }

    .footer-links a {
      font-size: 12px;
    }
  }
</style>
