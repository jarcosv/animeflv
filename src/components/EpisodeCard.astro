---
interface Props {
  title: string;
  cover?: string;
  episode?: number;
  genre?: string;
}

const { title, cover, episode = 1, genre = 'Sin género' } = Astro.props;
---

<div class="episode-card">
  <div class="episode-image">
    {cover ? (
      <img src={cover} alt={title} />
    ) : (
      <div class="episode-placeholder">
        <span class="play-icon">▶</span>
      </div>
    )}
    <div class="episode-badge">Cap. {episode}</div>
  </div>

  <div class="episode-info">
    <div class="episode-title">{title}</div>
    <div class="episode-genre">{genre}</div>
  </div>
</div>

<style>
  .episode-card {
    width: 160px;
    background-color: #1c1c1c;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.2s ease;
    cursor: pointer;
    flex-shrink: 0;
    border: 1px solid transparent;
  }

  .episode-card:hover {
    transform: scale(1.04);
    border-color: #e63946;
  }

  .episode-image {
    position: relative;
    width: 100%;
    height: 220px;
    background-color: #1a1a1a;
    overflow: hidden;
  }

  .episode-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .episode-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #1a1a1a;
  }

  .play-icon {
    font-size: 36px;
    color: #333333;
  }

  .episode-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background-color: #e63946;
    color: #ffffff;
    font-size: 10px;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .episode-info {
    padding: 8px;
  }

  .episode-title {
    font-size: 12px;
    color: #ffffff;
    font-weight: 500;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 4px;
    min-height: 24px;
  }

  .episode-genre {
    font-size: 11px;
    color: #aaaaaa;
  }

  @media (max-width: 768px) {
    .episode-card {
      width: 140px;
    }

    .episode-image {
      height: 200px;
    }
  }

  @media (max-width: 480px) {
    .episode-card {
      width: 130px;
    }

    .episode-image {
      height: 180px;
    }

    .episode-title {
      font-size: 11px;
    }

    .episode-genre {
      font-size: 10px;
    }
  }
</style>
