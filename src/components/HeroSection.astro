<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">Ver Anime Online Sub Español y Doblado</h1>
    <p class="hero-subtitle">Disfruta del mejor anime online en HD completamente gratis.</p>
  </div>
</section>

<style>
  .hero {
    padding: 48px 40px;
    border-radius: 12px;
    margin: 20px 40px 0;
    background-image: url('/bane.jpg');
    background-size: cover;
    background-position: center;
  }

  .hero-content {
    max-width: 1400px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 32px;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 16px;
    line-height: 1.3;
    background: transparent;
  }

  .hero-subtitle {
    font-size: 14px;
    color: #aaaaaa;
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 40px 24px;
    }

    .hero-title {
      font-size: 24px;
      margin-bottom: 12px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 32px 16px;
    }

    .hero-title {
      font-size: 18px;
    }

    .hero-subtitle {
      font-size: 13px;
    }
  }
</style>
