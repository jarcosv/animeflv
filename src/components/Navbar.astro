<nav class="navbar">
  <div class="navbar-container">
    <div class="navbar-logo">
      <img src="/logo.png" height="48" alt="AnimeFLV Logo" />
    </div>

    <button class="hamburger" id="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="navbar-links" id="navbarLinks">
      <a href="/" class="nav-link">Inicio</a>
      <a href="/directorio" class="nav-link">Directorio</a>
      <a href="/en-emision" class="nav-link">En Emisión</a>
      <a href="/peliculas" class="nav-link">Películas</a>
      <div class="dropdown">
        <button class="nav-link dropdown-btn">Género</button>
        <div class="dropdown-menu">
          <a href="/genero/accion">Acción</a>
          <a href="/genero/aventura">Aventura</a>
          <a href="/genero/comedia">Comedia</a>
          <a href="/genero/drama">Drama</a>
          <a href="/genero/fantasia">Fantasía</a>
          <a href="/genero/romance">Romance</a>
          <a href="/genero/slice-of-life">Slice of Life</a>
          <a href="/genero/sobrenatural">Sobrenatural</a>
        </div>
      </div>
    </div>

    <div class="navbar-search">
      <input 
        type="text" 
        class="search-input" 
        placeholder="Buscar anime..."
        id="searchInput"
      />
      <button class="search-button">🔍</button>
    </div>
  </div>
</nav>

<style>
  .navbar {
    background-color: #111111;
    border-bottom: 1px solid #1f1f1f;
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 12px 40px;
  }

  .navbar-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .navbar-logo img {
    height: 48px;
    width: auto;
    display: block;
  }

  .navbar-links {
    display: flex;
    gap: 24px;
    flex: 1;
    justify-content: center;
    align-items: center;
  }

  .nav-link {
    color: #aaaaaa;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s ease;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav-link:hover {
    color: #e63946;
  }

  .dropdown {
    position: relative;
  }

  .dropdown-btn {
    color: #aaaaaa;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s ease;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .dropdown-btn:hover {
    color: #e63946;
  }

  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: #1c1c1c;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 8px 0;
    min-width: 160px;
    z-index: 1000;
    margin-top: 8px;
  }

  .dropdown:hover .dropdown-menu {
    display: flex;
    flex-direction: column;
  }

  .dropdown-menu a {
    color: #aaaaaa;
    padding: 8px 16px;
    font-size: 13px;
    transition: all 0.2s ease;
  }

  .dropdown-menu a:hover {
    background-color: #2a2a2a;
    color: #e63946;
  }

  .navbar-search {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .search-input {
    background-color: #1c1c1c;
    color: #ffffff;
    border: 1px solid #2a2a2a;
    height: 36px;
    padding: 0 16px;
    border-radius: 20px;
    font-size: 13px;
    transition: border-color 0.2s ease;
    min-width: 200px;
  }

  .search-input:focus {
    outline: none;
    border-color: #e63946;
  }

  .search-input::placeholder {
    color: #666666;
  }

  .search-button {
    background-color: transparent;
    color: #e63946;
    border: none;
    cursor: pointer;
    font-size: 18px;
    padding: 6px 12px;
    transition: transform 0.2s ease;
  }

  .search-button:hover {
    transform: scale(1.1);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    background: none;
    border: none;
    cursor: pointer;
    gap: 6px;
  }

  .hamburger span {
    width: 24px;
    height: 2px;
    background-color: #e63946;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(10px, 10px);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 12px 24px;
    }

    .navbar-container {
      gap: 16px;
      padding: 0;
    }

    .hamburger {
      display: flex;
      order: 3;
    }

    .navbar-links {
      display: none;
      position: absolute;
      top: 70px;
      left: 0;
      right: 0;
      background-color: #111111;
      flex-direction: column;
      border-bottom: 1px solid #1f1f1f;
      padding: 20px;
      gap: 16px;
    }

    .navbar-links.active {
      display: flex;
    }

    .navbar-search {
      order: 2;
      gap: 4px;
    }

    .search-input {
      min-width: 120px;
      height: 32px;
      font-size: 12px;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 12px 16px;
    }

    .navbar-container {
      gap: 12px;
    }

    .navbar-logo img {
      height: 40px;
    }

    .search-input {
      min-width: 100px;
      padding: 0 12px;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const navbarLinks = document.getElementById('navbarLinks');

  if (hamburger && navbarLinks) {
    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navbarLinks.classList.toggle('active');
    });

    // Close menu when link is clicked
    const navLinks = navbarLinks.querySelectorAll('.nav-link');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        navbarLinks.classList.remove('active');
      });
    });
  }
</script>
