---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import AnimeCard from '../components/AnimeCard.astro';
import Footer from '../components/Footer.astro';

interface Anime {
  mal_id: number;
  title: string;
  images?: {
    jpg?: {
      image_url?: string;
    };
  };
  score?: number;
  type?: string;
}

let movies: Array<{title: string; cover?: string; type: string; rating: number}> = [];

// Fetch movies
try {
  const response = await fetch('https://api.jikan.moe/v4/top/anime?type=movie&limit=48');
  if (response.ok) {
    const data = await response.json();
    const animes = data.data || [];
    
    movies = animes.map((anime: Anime) => ({
      title: anime.title || 'Sin título',
      cover: anime.images?.jpg?.image_url,
      type: 'Película',
      rating: anime.score || 0
    }));
  }
} catch (error) {
  console.error('Error fetching movies:', error);
}

// Generate placeholder data if API fails
const placeholders = Array(48).fill(null).map(() => ({
  title: 'Cargando...',
  type: 'Película',
  rating: 0
}));

const displayMovies = movies.length > 0 ? movies : placeholders;
---

<MainLayout title="Películas - AnimeFLV">
  <Navbar />
  
  <main class="main-content">
    <section class="container page-header">
      <h1>Películas de Anime</h1>
      <p>Las mejores películas de anime en un solo lugar</p>
    </section>

    <section class="container">
      <div class="anime-grid-large">
        {displayMovies.map((movie) => (
          <AnimeCard 
            title={movie.title}
            cover={movie.cover}
            type={movie.type}
            rating={movie.rating}
          />
        ))}
      </div>
    </section>

    <section class="seo-block">
      <div class="container">
        <div class="seo-content">
          <h2>Películas de Anime Completas</h2>
          <p>
            Disfruta de las mejores películas de anime de todos los tiempos. Desde obras maestras clásicas hasta los últimos estrenos cinematográficos, encontrarás una amplia colección de películas de calidad en alta definición. Todas están disponibles para ver completamente gratis.
          </p>
          <p>
            Cada película incluye información detallada sobre su director, estudio de producción, género y clasificación. Muchas de nuestras películas son spin-offs o secuelas de series populares, ofreciendo una experiencia cinematográfica épica del anime.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>

<style>
  .main-content {
    background-color: #0d0d0d;
    padding: 24px 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .page-header {
    text-align: center;
    padding: 40px 40px 24px;
    border-bottom: 1px solid #1f1f1f;
    margin-bottom: 40px;
  }

  .page-header h1 {
    font-size: 32px;
    color: #ffffff;
    margin-bottom: 8px;
  }

  .page-header p {
    color: #aaaaaa;
    font-size: 14px;
  }

  .anime-grid-large {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 12px;
    width: 100%;
    margin-bottom: 48px;
  }

  .seo-block {
    background-color: #111111;
    padding: 30px 40px;
    border-top: 1px solid #1f1f1f;
    border-bottom: 1px solid #1f1f1f;
  }

  .seo-content {
    max-width: 1400px;
    margin: 0 auto;
  }

  .seo-content h2 {
    font-size: 18px;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 16px;
    padding-left: 12px;
    border-left: 3px solid #e63946;
  }

  .seo-content p {
    color: #777777;
    font-size: 13px;
    line-height: 1.8;
    margin-bottom: 12px;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 24px;
    }

    .page-header {
      padding: 32px 24px 20px;
    }

    .page-header h1 {
      font-size: 24px;
    }

    .anime-grid-large {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .seo-block {
      padding: 24px;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 16px;
    }

    .page-header {
      padding: 24px 16px 16px;
    }

    .page-header h1 {
      font-size: 18px;
    }

    .anime-grid-large {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .seo-block {
      padding: 20px 16px;
    }

    .seo-content p {
      font-size: 11px;
    }
  }
</style>
